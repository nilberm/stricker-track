{
  "name": "@sticker-track/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prebuild": "node scripts/validate-public-env.mjs",
    "build": "next build",
    "predev": "node scripts/clean-next-cache.mjs",
    "dev": "next dev --turbo",
    "lint": "tsc --noEmit && pnpm messages:check",
    "start": "next start",
    "test": "jest && pnpm messages:check",
    "typecheck": "tsc --noEmit",
    "messages:check": "node scripts/validate-messages.mjs"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.0.1",
    "@sticker-track/shared": "workspace:*",
    "@tanstack/react-query": "^5.101.0",
    "framer-motion": "^12.40.0",
    "lucide-react": "^0.475.0",
    "next": "^15.3.2",
    "next-intl": "^4.1.0",
    "page-flip": "^2.0.7",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.56.4",
    "tesseract.js": "^7.0.0",
    "zod": "^3.25.42"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.8",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.29",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "tailwindcss": "^4.1.8",
    "ts-jest": "^29.2.6",
    "typescript": "^5.8.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts",
      "tsx"
    ],
    "rootDir": "src",
    "testEnvironment": "jsdom",
    "testRegex": ".*\\.spec\\.tsx?$",
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": {
            "jsx": "react-jsx",
            "module": "commonjs",
            "moduleResolution": "node"
          }
        }
      ]
    }
  }
}
