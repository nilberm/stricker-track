NODE_ENV=development
POSTGRES_DB=sticker_track
POSTGRES_USER=sticker_track
POSTGRES_PASSWORD=sticker_track
POSTGRES_PORT=55432
DATABASE_URL=postgresql://sticker_track:sticker_track@127.0.0.1:55432/sticker_track?schema=public
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN_SECONDS=86400
API_PORT=3001
WEB_PORT=3000
APP_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BUY_ME_A_COFFEE_URL=
NEXT_PUBLIC_SCANNER_DEBUG=false
RATE_LIMIT_TTL=60000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=5
RESET_RATE_LIMIT_MAX=3
SCANNER_RATE_LIMIT_MAX=60
ADMIN_RATE_LIMIT_MAX=20
PASSWORD_RESET_EXPIRES_MINUTES=30
WIKIDATA_USER_AGENT=StickerTrack/0.1 (development)
EXTERNAL_PROVIDER_TIMEOUT_MS=8000
EXTERNAL_PROVIDER_RETRY_LIMIT=1
LOG_LEVEL=debug
SWAGGER_ENABLED=true
CSV_MAX_BYTES=2000000
