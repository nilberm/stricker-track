NODE_ENV=production
POSTGRES_DB=sticker_track
POSTGRES_USER=sticker_track_app
POSTGRES_PASSWORD=
DATABASE_URL=postgresql://sticker_track_app:CHANGE_ME@postgres:5432/sticker_track?schema=public&sslmode=require
JWT_SECRET=
JWT_EXPIRES_IN_SECONDS=3600
API_PORT=3001
WEB_PORT=3000
APP_URL=https://app.example.com
CORS_ALLOWED_ORIGINS=https://app.example.com
NEXT_PUBLIC_API_URL=https://api.example.com/api/v1
NEXT_PUBLIC_APP_URL=https://app.example.com
NEXT_PUBLIC_BUY_ME_A_COFFEE_URL=
NEXT_PUBLIC_SCANNER_DEBUG=false
RATE_LIMIT_TTL=60000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=5
RESET_RATE_LIMIT_MAX=3
SCANNER_RATE_LIMIT_MAX=60
ADMIN_RATE_LIMIT_MAX=20
PASSWORD_RESET_EXPIRES_MINUTES=30
WIKIDATA_USER_AGENT=StickerTrack/1.0 (contact@example.com)
EXTERNAL_PROVIDER_TIMEOUT_MS=8000
EXTERNAL_PROVIDER_RETRY_LIMIT=1
LOG_LEVEL=info
SWAGGER_ENABLED=false
CSV_MAX_BYTES=2000000
